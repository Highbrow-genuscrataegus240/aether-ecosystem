generator client {
  provider = "prisma-client-js"
  output   = "./generated/supply"
}

datasource db {
  provider = "sqlite"
  url      = "file:./supply.db"
}

model Supplier {
  id              String   @id @default(cuid())
  name            String
  leadTimeDays    Int      @default(7)
  contactEmail    String
  rating          Float?   @default(0)
  onTimePercent   Float?   @default(0)
  totalOrders     Int?     @default(0)
  fulfillmentRate Float?   @default(0)
  location        String?
  createdAt       DateTime @default(now())
}

model Warehouse {
  id       String @id @default(cuid())
  name     String
  location String
  capacity Int    @default(1000)
}

model Product {
  id           String   @id @default(cuid())
  name         String
  sku          String
  barcode      String?
  category     String
  price        Float
  cost         Float?   @default(0)
  stock        Int      @default(0)
  reorderLevel Int      @default(10)
  supplierId   String
  warehouseId  String?
  imageUrl     String?
  createdAt    DateTime @default(now())
}

model Sale {
  id        String   @id @default(cuid())
  productId String
  quantity  Int
  date      DateTime @default(now())
}

model StockTransfer {
  id              String   @id @default(cuid())
  productId       String
  fromWarehouseId String
  toWarehouseId   String
  quantity        Int
  notes           String?
  createdAt       DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityName String
  details    String?
  createdAt  DateTime @default(now())
}

model Category {
  id     String @id @default(cuid())
  name   String @unique
  userId String
}
