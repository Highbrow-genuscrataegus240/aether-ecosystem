generator client {
  provider = "prisma-client-js"
  output   = "./generated/crm"
}

datasource db {
  provider = "sqlite"
  url      = "file:./crm.db"
}

model Client {
  id      Int    @id @default(autoincrement())
  name    String
  company String
  email   String
  status  String
}

model Task {
  id        Int     @id @default(autoincrement())
  title     String
  time      String
  type      String
  completed Boolean @default(false)
}

model Deal {
  id      Int    @id @default(autoincrement())
  client  String
  value   Float
  days    Int
  stageId String
}
